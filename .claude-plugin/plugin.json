{
  "name": "critique",
  "description": "Permanent critical mindset mode. Surfaces real bugs, questionable decisions, and unhandled edge cases — ordered by impact, no sugarcoating.",
  "author": {
    "name": "Alfafis",
    "url": "https://github.com/Alfafis"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/critica-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading critique mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/critica-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking critique mode..."
          }
        ]
      }
    ]
  }
}
